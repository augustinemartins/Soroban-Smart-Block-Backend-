# ─── Docker Compose database credentials ─────────────────────────────────────
# REQUIRED when using docker-compose. Use a strong, unique password.
# Never commit real credentials; rotate immediately if leaked.
# Exception process: document any known-vulnerable dependency below with an
# expiry date, e.g.: # EXCEPTION: lodash@4.17.20 CVE-2021-23337 expires 2025-12-31
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_before_deploying

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Active network ───────────────────────────────────────────────────────────
# Which network this server instance serves.
# Valid values: testnet | mainnet | devnet
# The matching NETWORK_* variables below are loaded automatically.
STELLAR_NETWORK=testnet

# ─── Testnet ──────────────────────────────────────────────────────────────────
TESTNET_DATABASE_URL="postgresql://postgres:password@localhost:5432/soroban_testnet"
TESTNET_READ_REPLICA_URL="postgresql://postgres:password@localhost:5432/soroban_testnet"
TESTNET_RPC_URL=https://soroban-testnet.stellar.org
TESTNET_RPC_WS_URL=wss://soroban-testnet.stellar.org
TESTNET_HORIZON_URL=https://horizon-testnet.stellar.org
TESTNET_PASSPHRASE="Test SDF Network ; September 2015"
TESTNET_API_SUBDOMAIN=testnet-api.localhost
TESTNET_CACHE_URL=memory://

# ─── Mainnet ──────────────────────────────────────────────────────────────────
MAINNET_DATABASE_URL="postgresql://postgres:password@localhost:5433/soroban_mainnet"
MAINNET_READ_REPLICA_URL="postgresql://postgres:password@localhost:5433/soroban_mainnet"
# Replace <API_KEY> with your provider key (e.g. Validation Cloud, QuickNode)
MAINNET_RPC_URL=https://mainnet.stellar.validationcloud.io/v1/<API_KEY>
MAINNET_RPC_WS_URL=wss://mainnet.stellar.validationcloud.io/v1/<API_KEY>
MAINNET_HORIZON_URL=https://horizon.stellar.org
MAINNET_PASSPHRASE="Public Global Stellar Network ; September 2015"
MAINNET_API_SUBDOMAIN=api.localhost
MAINNET_CACHE_URL=memory://

# ─── Devnet (local Stellar Quickstart) ────────────────────────────────────────
DEVNET_DATABASE_URL="postgresql://postgres:password@localhost:5434/soroban_devnet"
DEVNET_READ_REPLICA_URL="postgresql://postgres:password@localhost:5434/soroban_devnet"
DEVNET_RPC_URL=http://localhost:8000/soroban/rpc
DEVNET_RPC_WS_URL=ws://localhost:8000/soroban/rpc
DEVNET_HORIZON_URL=http://localhost:8000
DEVNET_PASSPHRASE="Standalone Network ; February 2017"
DEVNET_API_SUBDOMAIN=devnet-api.localhost
DEVNET_CACHE_URL=memory://

# ─── Indexer ──────────────────────────────────────────────────────────────────
INDEXER_START_LEDGER=0
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_BATCH_SIZE=100
# Number of parallel workers during historical catch-up (1 = sequential)
INDEXER_CATCHUP_WORKERS=4

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_PUBLIC_MAX=100
RATE_LIMIT_DEVELOPER_MAX=300
RATE_LIMIT_PREMIUM_MAX=1000
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_DEVELOPER_WINDOW_MS=60000
RATE_LIMIT_PREMIUM_WINDOW_MS=60000
RATE_LIMIT_ADAPTIVE_ENABLED=true
RATE_LIMIT_ADAPTIVE_THRESHOLD=0.85
RATE_LIMIT_ADAPTIVE_MULTIPLIER=0.75
# Optional: set to a value > 0 to trigger adaptive throttling based on server load
RATE_LIMIT_LOAD_FACTOR=0
# Optional: shared Redis store so rate limits are enforced across multiple API
# instances (e.g. Docker Compose scale-out). Omit to use the in-memory fallback.
# REDIS_URL=redis://localhost:6379

# ─── Archival / TTL (cold storage) ───────────────────────────────────────────
# Days before raw XDR is archived to S3 (parsed/human-readable data stays in DB)
RAW_XDR_RETENTION_DAYS=90
# Rows processed per archival batch
ARCHIVE_BATCH_SIZE=500
# AWS S3 bucket for cold XDR storage (leave unset to skip archival)
ARCHIVE_S3_BUCKET=soroban-xdr-archive
# S3 storage class: STANDARD_IA (default) | GLACIER | DEEP_ARCHIVE
ARCHIVE_S3_STORAGE_CLASS=STANDARD_IA
AWS_REGION=us-east-1
# AWS_ENDPOINT_URL=http://localhost:4566  # LocalStack for local dev

# ─── Audit Platform ───────────────────────────────────────────────────────────
# Signing key for HMAC-SHA256 certificate signatures (generate a strong secret)
AUDIT_SIGNING_KEY=change-me-to-a-strong-random-secret

# Admin key required for /verify, /suspend, submission review endpoints
AUDIT_ADMIN_KEY=change-me-admin-key

# Continuous monitor: poll interval in ms (default: 60000 = 1 min)
AUDIT_MONITOR_POLL_MS=60000

# TVL drop % that triggers a monitoring signal (default: 15)
AUDIT_TVL_DROP_PCT=15

# User count drop % that triggers a monitoring signal (default: 20)
AUDIT_USER_DROP_PCT=20

# Minimum score drop (points) that fires a score_drop WebSocket alert (default: 10)
AUDIT_SCORE_ALERT_DROP=10

# Scheduler startup delay before first batch run in ms (default: 60000)
# AUDIT_SCHEDULER_STARTUP_DELAY_MS=60000

# ─── On-Chain Certificate Anchoring ──────────────────────────────────────────
# Set ANCHOR_ENABLED=true to submit real Stellar transactions.
# Without this, anchoring runs in simulation mode (deterministic hash, no fees).
ANCHOR_ENABLED=false

# Stellar secret key of the funded account used to sign anchor transactions.
# Required when ANCHOR_ENABLED=true. Keep this secret — never commit to VCS.
# ANCHOR_SECRET_KEY=S...

# Base fee in stroops for anchor transactions (default: 10000 = 0.001 XLM)
ANCHOR_BASE_FEE=10000

# Transaction timeout in seconds (default: 30)
ANCHOR_TIMEOUT_SEC=30

# Public base URL for generating verification/QR links in certificates and badges
PUBLIC_API_BASE_URL=https://explorer.soroban.network

# ─── Audit Notification Delivery ─────────────────────────────────────────────
# Email (SMTP) — required for email channel delivery
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=audit@soroban.network

# Webhook and Slack channels are configured per-subscription (no global setting).
# The webhook signing secret is also stored per-subscription.

# ─── Formal Verification ─────────────────────────────────────────────────────
# Certora Prover API key (required for certora tool)
# CERTORA_KEY=your-certora-key

# Timeout for formal verification tool execution in ms (default: 120000 = 2 min)
# FORMAL_VERIF_TIMEOUT_MS=120000

# Certificate expiry check interval in ms (default: 21600000 = 6 hours)
# AUDIT_EXPIRY_CHECK_INTERVAL_MS=21600000

# ─── Slack/Discord Bot Integration ───────────────────────────────────────────
# Slack signing secret — from your Slack App's "Basic Information" page
# Used to verify that slash command requests genuinely come from Slack
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# Slack incoming webhook URL (optional — for workspace-wide digest posts)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Discord application public key — from https://discord.com/developers/applications
# Used to verify Ed25519 signatures on interaction requests
# DISCORD_PUBLIC_KEY=your-discord-app-public-key

# Discord application ID — needed to post follow-up messages to interactions
# DISCORD_APPLICATION_ID=your-discord-application-id

# ─── PagerDuty / Opsgenie Incident Management ────────────────────────────────
# PagerDuty Events API v2 integration key (from your PagerDuty service settings)
# Incidents fire when: critical finding + TVL > $1M, score < 30, or sig failure
# PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key

# Opsgenie Alert API key (from Opsgenie Settings > API Key Management)
# OPSGENIE_API_KEY=your-opsgenie-api-key

# Opsgenie region: "us" (default) or "eu"
# OPSGENIE_REGION=us

# TVL threshold in USD above which a critical finding fires a P1 incident (default: $1M)
# INCIDENT_TVL_THRESHOLD=1000000

# Audit score threshold below which a P1 incident fires (default: 30)
# CRITICAL_SCORE_THRESHOLD=30

# Allow test incident dispatch in production (default: false)
# TEST_INCIDENTS_ENABLED=false
# ─── Fiat On/Off-Ramp Gateway ─────────────────────────────────────────────────
# Platform fee applied on top of provider fees (percentage, e.g. 0.5 = 0.5%)
RAMP_PLATFORM_FEE_PCT=0.5
# URL users are redirected to after completing a provider widget flow
RAMP_RETURN_URL=https://explorer.example.com/ramp/complete

# MoonPay
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_WEBHOOK_SECRET=
# MOONPAY_BASE_URL=https://api.moonpay.com

# Transak
TRANSAK_API_KEY=
TRANSAK_SECRET_KEY=
TRANSAK_ENV=production
# TRANSAK_BASE_URL=https://api.transak.com

# Ramp Network
RAMP_NETWORK_API_KEY=
# RAMP_NETWORK_BASE_URL=https://api.ramp.network/api/host-api

# Banxa
BANXA_API_KEY=
BANXA_SECRET_KEY=
# BANXA_BASE_URL=https://banxa.com

# Stripe Crypto On-ramp (uses STRIPE_SECRET_KEY already defined above)
STRIPE_RAMP_WEBHOOK_SECRET=
