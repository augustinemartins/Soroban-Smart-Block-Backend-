// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contract {
  id          String   @id @default(cuid())
  address     String   @unique
  name        String?
  description String?
  abi         Json?    // ABI-like metadata: functions, events, types
  isToken     Boolean  @default(false)
  tokenSymbol String?
  tokenName   String?
  tokenDecimals Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]
  events       Event[]

  @@index([address])
}

model Transaction {
  id              String   @id @default(cuid())
  hash            String   @unique
  ledger          Int
  ledgerCloseTime DateTime
  sourceAccount   String
  contractAddress String?
  functionName    String?
  functionArgs    Json?    // decoded args
  rawXdr          String
  status          String   // success | failed
  humanReadable   String?  // "Address X swapped 100 USDC → 98.7 XLM"
  feeCharged      String?
  createdAt       DateTime @default(now())

  contract Contract? @relation(fields: [contractAddress], references: [address])
  events   Event[]

  @@index([hash])
  @@index([sourceAccount])
  @@index([contractAddress])
  @@index([ledger])
}

model Event {
  id              String   @id @default(cuid())
  transactionHash String
  contractAddress String
  eventType       String   // transfer | swap | mint | burn | custom
  topics          Json     // raw topics
  data            Json     // raw data
  decoded         Json?    // human-readable decoded event
  ledger          Int
  ledgerCloseTime DateTime
  createdAt       DateTime @default(now())

  transaction Transaction @relation(fields: [transactionHash], references: [hash])
  contract    Contract    @relation(fields: [contractAddress], references: [address])

  @@index([transactionHash])
  @@index([contractAddress])
  @@index([eventType])
  @@index([ledger])
}

model VulnerabilityAdvisory {
  id            String   @id @default(cuid())
  advisoryId    String   @unique
  title         String
  description   String?
  severity      String   // low | medium | high | critical
  affectedPackage String?
  affectedContracts String[] // list of affected contract addresses
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  propagationAnalyses PropagationAnalysis[]

  @@index([severity])
}

model PropagationAnalysis {
  id              String   @id @default(cuid())
  advisoryId      String
  vulnerableContract String
  directAffected  String[] // list of directly affected contract addresses
  affectedByDepth Json     // JSON map of depth -> string[] (e.g. { "1": ["addr1"], "2": ["addr2"] })
  totalValueAtRisk Decimal? @default(0)
  analysisDepth   Int      @default(5)
  analyzedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  advisory VulnerabilityAdvisory @relation(fields: [advisoryId], references: [id])

  @@index([advisoryId])
  @@index([vulnerableContract])
}

model DexPool {
  id             String   @id @default(cuid())
  address        String   @unique
  name           String?
  tvlUsd         Decimal  @default(0)
  tokenA         String?
  tokenB         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([address])
}

model IndexerState {
  id            String   @id @default("singleton")
  lastLedger    Int      @default(0)
  updatedAt     DateTime @updatedAt
}

model FailedItem {
  id          String   @id @default(cuid())
  itemType    String   // "transaction" | "event"
  itemId      String   // tx hash or event id
  ledger      Int
  rawXdr      String?  // raw XDR that failed to decode
  errorMsg    String
  errorStack  String?
  context     Json?    // extra context (topics, data, etc.)
  retryCount  Int      @default(0)
  dead        Boolean  @default(false)  // true = max retries exceeded
  createdAt   DateTime @default(now())
  lastTriedAt DateTime @default(now())

  @@index([itemType, dead])
  @@index([ledger])
}
